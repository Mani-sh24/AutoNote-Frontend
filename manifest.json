{
  "manifest_version": 3,
  "name": "ScribeWave Tab Transcriber",
  "version": "1.2.0",
  "minimum_chrome_version": "116",
  "description": "Capture tab audio and keep transcription summaries ready when you return.",
  "permissions": ["tabCapture", "offscreen", "storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScribeWave"
  }
}
