{
  "manifest_version": 3,
  "name": "Audio PCM Capture & Monitor",
  "version": "1.1",
  "permissions": ["tabCapture", "offscreen", "storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["node_modules/lamejs/lame.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}